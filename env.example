# Copy this file to .env and fill in your real keys.
# NEVER commit .env to Git.

# Required: LLM judge, RAG generation, safety classifier, prompt generation
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Required: embeddings only (ingest + rag_pipeline)
OPENAI_API_KEY=your-openai-api-key-here

# Optional overrides (all have defaults in config.py):
# RAGPROBE_JUDGE_MODEL=claude-haiku-4-5-20251001
# RAGPROBE_EMBED_MODEL=text-embedding-3-small
# RAGPROBE_CHUNK_TOKENS=512
# RAGPROBE_FAITHFULNESS_THRESHOLD=0.75
